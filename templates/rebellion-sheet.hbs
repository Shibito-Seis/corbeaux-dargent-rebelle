<section class="rebellion-sheet">
  <header class="rebellion-header">
    <div>
      <h1>Les Corbeaux d'Argent</h1>
      <p>Fiche de rébellion</p>
    </div>

    <div class="rebellion-summary major-scores">
      <label>
        Notoriété
        <input type="number" name="notoriety" value="{{rebellion.notoriety}}" min="0" step="1" {{#unless editable}}disabled{{/unless}}>
      </label>

      <label>
        Autorité
        <input type="number" name="authority" value="{{rebellion.authority}}" min="0" step="1" {{#unless editable}}disabled{{/unless}}>
      </label>

      <label>
        Libération
        <input type="number" name="liberation" value="{{rebellion.liberation}}" min="0" step="1" {{#unless editable}}disabled{{/unless}}>
      </label>
    </div>
  </header>

  <section class="manual-notice">
    <strong>Gestion manuelle :</strong>
    le MJ ajuste Notoriété, Autorité et Libération selon l'évolution de la campagne.
  </section>

  <section class="rebellion-body">
    <div class="asset-columns">
      {{#each assetGroups as |group|}}
        <section class="asset-column asset-column-{{group.key}}">
          <header>
            <h2>{{group.label}}</h2>
          </header>

          <ol class="asset-list">
            {{#each group.assets as |asset index|}}
              <li class="asset-row">
                <span class="asset-index">{{asset.displayIndex}}</span>

                <input
                  type="text"
                  name="{{group.key}}.{{index}}.name"
                  value="{{asset.name}}"
                  placeholder="Asset"
                  {{#unless ../../editable}}disabled{{/unless}}
                >

                <input
                  type="number"
                  name="{{group.key}}.{{index}}.value"
                  value="{{asset.value}}"
                  min="0"
                  max="9"
                  step="1"
                  {{#unless ../../editable}}disabled{{/unless}}
                >
              </li>
            {{/each}}
          </ol>
        </section>
      {{/each}}
    </div>

    <section class="rebellion-notes">
      <h2>Notes MJ</h2>
      <textarea name="notes" rows="5" {{#unless editable}}disabled{{/unless}}>{{rebellion.notes}}</textarea>
    </section>
  </section>

  <footer class="rebellion-footer">
    <button type="button" data-rebellion-save {{#unless editable}}disabled{{/unless}}>
      Sauvegarder
    </button>

    <button type="button" data-rebellion-reset {{#unless editable}}disabled{{/unless}}>
      Réinitialiser
    </button>
  </footer>
</section>