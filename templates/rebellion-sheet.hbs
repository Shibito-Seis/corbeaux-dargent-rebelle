<section class="rebellion-sheet">
  <header class="rebellion-header">
    <div>
      <h1>Les Corbeaux d'Argent</h1>
      <p>Fiche de rébellion</p>
    </div>

    <div class="rebellion-summary">
      <label>
        Autorité
        <input type="number" name="authority" value="{{authority}}" min="0" step="1" {{#unless editable}}disabled{{/unless}}>
      </label>

      <div class="liberation-score">
        <span>Libération</span>
        <strong>{{liberation}}</strong>
      </div>
    </div>
  </header>

  <section class="rebellion-progress">
    <div class="progress-label">
      <span>Progression vers la libération</span>
      <span>{{liberation}} / {{authority}}</span>
    </div>

    <div class="progress-bar">
      <div class="progress-fill" style="width: {{victoryRatio}}%;"></div>
    </div>
  </section>

  <section class="rebellion-body">
    <div class="asset-columns">
      {{#each assetGroups as |group|}}
        <section class="asset-column asset-column-{{group.key}}">
          <header>
            <h2>{{group.label}}</h2>
            <span>Total : {{group.total}}</span>
          </header>

          <ol class="asset-list">
            {{#each group.assets as |asset index|}}
              <li class="asset-row">
                <span class="asset-index">{{add index 1}}</span>

                <input
                  type="text"
                  name="{{group.key}}.{{index}}.name"
                  value="{{asset.name}}"
                  placeholder="Asset"
                  {{#unless ../../editable}}disabled{{/unless}}
                >

                <input
                  type="number"
                  name="{{group.key}}.{{index}}.value"
                  value="{{asset.value}}"
                  min="0"
                  max="9"
                  step="1"
                  {{#unless ../../editable}}disabled{{/unless}}
                >
              </li>
            {{/each}}
          </ol>

          <button type="button" data-action="rollRebellion" data-stat="{{group.key}}">
            Lancer une action — {{group.label}}
          </button>
        </section>
      {{/each}}
    </div>

    <section class="authority-tools">
      <h2>Autorité de Thrune</h2>

      <div class="authority-controls">
        <label>
          Niveau / valeur
          <input type="number" name="authorityDelta" value="1" min="1" step="1" {{#unless editable}}disabled{{/unless}}>
        </label>

        <button type="button" data-action="adjustAuthority" data-mode="captured" {{#unless editable}}disabled{{/unless}}>
          + PJ capturé
        </button>

        <button type="button" data-action="adjustAuthority" data-mode="encounter" {{#unless editable}}disabled{{/unless}}>
          - Rencontre vaincue
        </button>
      </div>
    </section>

    <section class="rebellion-notes">
      <h2>Notes MJ</h2>
      <textarea name="notes" rows="5" {{#unless editable}}disabled{{/unless}}>{{rebellion.notes}}</textarea>
    </section>
  </section>

  <footer class="rebellion-footer">
    <button type="button" data-action="saveRebellion" {{#unless editable}}disabled{{/unless}}>
      Sauvegarder
    </button>

    <button type="button" data-action="resetRebellion" {{#unless editable}}disabled{{/unless}}>
      Réinitialiser
    </button>
  </footer>
</section>